# ═══════════════════════════════════════════
# HakimiVisa Production Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.prod and fill in the values

# ── MySQL ──
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_DATABASE=hakimi_visa
MYSQL_USER=hakimi
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ── URLs (change to your domain) ──
CORS_ORIGIN=https://yourdomain.com
APP_URL=https://yourdomain.com

# ── Firebase (path to service account JSON inside container) ──
FIREBASE_CREDENTIALS=secrets/hakimivisa-app-firebase-adminsdk-fbsvc-3494ed0331.json

# ── Frontend ──
VITE_API_URL=https://yourdomain.com/api
