# ==========================================
# HakimiVisa Backend Environment Variables
# ==========================================
# Copy this file to .env and adjust values

# Server
PORT=4000
NODE_ENV=production

# Database
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://hakimi:hakimi_pass@localhost:3306/hakimi_visa"

# JWT Authentication
JWT_SECRET=change-this-to-a-64-char-random-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-this-to-another-64-char-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Authentication
# Keep disabled in production; users should be provisioned by seed/admin workflows.
ALLOW_PUBLIC_REGISTRATION=false

# CORS - comma-separated origins
CORS_ORIGIN=https://your-frontend-domain.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# MySQL Dump Path (for backups)
# MYSQLDUMP_PATH=/usr/bin/mysqldump

# Frontend URL (for QR codes, tracking links)
APP_URL=https://your-frontend-domain.com
